# Supabase configuration
#
# These are the PUBLIC anon / publishable values. They are baked into the
# frontend bundle and are safe to expose in a browser — your data is protected
# by Row Level Security, not by hiding this key. Never put the service_role key here.
#
# For local dev: copy this file to ".env" and fill in your real values.
# For GitHub Pages: set these as repository secrets (see .github/workflows/deploy.yml).

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
